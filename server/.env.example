# ── TestMart API — environment ───────────────────────────────────────────────
# Copy to `.env` and fill in for production. Everything here is OPTIONAL locally
# (the app has sensible dev defaults). `.env` is gitignored — never commit secrets.

# API port. On most hosts (e.g. Render) this is injected automatically.
PORT=5000

# MongoDB connection string. Leave BLANK to use an in-memory DB (dev/test).
# In production, set this to your MongoDB Atlas connection string:
# MONGO_URI=mongodb+srv://<user>:<pass>@<cluster>.mongodb.net/testmart?retryWrites=true&w=majority

# JWT signing secret — MUST be a long random value in production.
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES=7d

# Allowed CORS origin (credentialed). Unused for same-origin hosting.
CLIENT_URL=http://localhost:5173

# Cookie flags — pick per hosting topology:
#   same-origin (one service): COOKIE_SECURE=true   COOKIE_SAMESITE=lax
#   split-domain hosting:      COOKIE_SECURE=true   COOKIE_SAMESITE=none
COOKIE_SECURE=false
COOKIE_SAMESITE=lax

# "true" => the API also serves the built React client (single-service deploy).
SERVE_CLIENT=false

# ── Rate limiting ─────────────────────────────────────────────────────────────
# Protects a PUBLIC deploy from abuse (e.g. scripted mass registration). The global
# limiter is only active when enabled here — keep OFF locally so tests are never throttled.
# (login/register have their own stricter per-route limits when enabled.)
RATE_LIMIT_ENABLED=false
RATE_LIMIT_TTL=60000   # window in ms
RATE_LIMIT_MAX=100     # max requests per window per IP

# ── Test reset endpoint ───────────────────────────────────────────────────────
# POST /api/test/reset wipes + reseeds the DB to a known state (for automation).
# Keep OFF (unset) on any public instance — otherwise anyone could wipe your data.
# Turn ON only for local / CI test runs.
ENABLE_TEST_RESET=false
# Optional extra guard: if set, callers must send header  x-test-reset-token: <value>
# TEST_RESET_TOKEN=some-long-random-string
